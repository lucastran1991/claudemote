# Generated from Caddyfile.template by start.sh — DO NOT EDIT DIRECTLY
{{HOSTNAME}} {
  # Compress everything EXCEPT SSE streams. Caddy's `encode` directive
  # uses a named matcher for exclusion; putting `not` inside the
  # `encode { }` block is parsed as an encoder module name and fails.
  @compressible not path /api/jobs/*/stream
  encode @compressible gzip

  # SSE streams: flush_interval -1 disables response buffering so each
  # event is written to the client as soon as the backend emits it.
  # HTTP/1.1 is required — HTTP/2 multiplexing can hold frames and
  # interfere with chunked-transfer SSE semantics.
  @stream path /api/jobs/*/stream
  handle @stream {
    reverse_proxy localhost:{{API_PORT}} {
      flush_interval -1
      transport http {
        versions 1.1
      }
    }
  }

  # NextAuth routes must reach Next.js, not the Go backend
  handle /api/auth/* {
    reverse_proxy localhost:{{WEB_PORT}}
  }

  # All other /api/* requests go to the Go backend without flush override
  handle /api/* {
    reverse_proxy localhost:{{API_PORT}}
  }

  # Everything else (pages, static assets, Next.js API routes) → Next.js
  handle {
    reverse_proxy localhost:{{WEB_PORT}}
  }
}
