# claudemote backend configuration
# Copy to .env and fill in real values before running.
# Never commit .env to version control.
#
# In production, non-secret config is injected by ecosystem.config.cjs from
# system.cfg.json. The values below are defaults for local development
# (go run ./cmd/server) and for the start.sh bootstrap sed step.

# --- Auth (secrets) ---
# Minimum 32 random characters. Generate with: openssl rand -hex 32
JWT_SECRET=change-me-to-a-random-string-min-32-chars

# Admin credentials used to validate login.
# Create the admin user via: make create-admin
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=$2a$10$changeme_replace_with_real_bcrypt_hash

# --- Claude Code binary ---
# Absolute path to the claude binary on the host.
# Auto-detected by ./start.sh --bootstrap via `command -v claude`.
CLAUDE_BIN=

# --- Non-secret config (overridden by PM2 via system.cfg.json in production) ---
DB_PATH=./claudemote.db
WORK_DIR=/opt/atomiton/claudemote
