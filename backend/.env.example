# claudemote backend configuration
# Copy to .env and fill in real values before running.
# Never commit .env to version control.

# --- Server ---
PORT=8080

# --- Database ---
# Path to SQLite file. Created automatically on first boot.
DB_PATH=./claudemote.db

# --- Auth ---
# Minimum 32 random characters. Generate with: openssl rand -hex 32
JWT_SECRET=change-me-to-a-random-string-min-32-chars

# Admin credentials stored in the users table.
# Create via: go run ./cmd/create-admin -username=admin -password=secret
# ADMIN_USERNAME and ADMIN_PASSWORD_HASH are used at runtime to validate
# login; the actual bcrypt hash is stored in the DB after create-admin runs.
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=$2a$10$changeme_replace_with_real_bcrypt_hash

# --- CORS ---
# Origin(s) allowed to call the API. Must match the Next.js frontend URL.
CORS_ORIGIN=http://localhost:3000

# --- Worker pool (Phase 02) ---
# Number of concurrent Claude Code subprocesses.
WORKER_COUNT=2

# --- Claude Code subprocess ---
# Absolute path to the claude binary on the host.
CLAUDE_BIN=/usr/local/bin/claude
# Default model used when the client does not specify one.
CLAUDE_DEFAULT_MODEL=claude-sonnet-4-6
# Permission mode passed to claude -p. bypassPermissions required for headless.
CLAUDE_PERMISSION_MODE=bypassPermissions

# --- Job limits ---
# Wall-clock timeout per job in minutes.
JOB_TIMEOUT_MIN=30
# Maximum API spend per job in USD. Job is auto-cancelled if exceeded.
MAX_COST_PER_JOB_USD=1.00

# --- Log retention ---
# Number of days to keep job_logs rows after job completion.
JOB_LOG_RETENTION_DAYS=14

# --- Working directory ---
# Absolute path to the repository Claude Code will run against.
# Required — server refuses to start without this.
# Default = self-hosting: claudemote operates on its own source tree.
# Override only if you want Claude to work on a different repo on this host.
WORK_DIR=/opt/atomiton/claudemote
