# claudemote frontend configuration
# Copy to .env.local and fill in real values. Never commit .env.local.
#
# In production, non-secret config is injected by ecosystem.config.cjs from
# system.cfg.json. The values below are defaults for local development
# (pnpm dev) and for the start.sh bootstrap sed step.

# --- Secrets ---
# NextAuth v5 signing secret. Generate with: openssl rand -base64 32
AUTH_SECRET=replace-me-with-a-random-secret
# NextAuth v4 compatibility alias — set to the same value as AUTH_SECRET.
NEXTAUTH_SECRET=replace-me-with-a-random-secret

# --- Non-secret config (overridden by PM2 via system.cfg.json in production) ---
NEXTAUTH_URL=http://localhost:8088
BACKEND_URL=http://localhost:8888
NEXT_PUBLIC_BACKEND_URL=http://localhost:8888
