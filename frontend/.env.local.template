# Copy this file to .env.local and fill in the values.
# .env.local is gitignored — never commit secrets.

# Required: URL this Next.js app is served from (used by NextAuth for callbacks)
NEXTAUTH_URL=http://localhost:3000

# Required: NextAuth v5 signing secret (AUTH_SECRET is the canonical name in v5).
# NEXTAUTH_SECRET is kept as fallback for v4 compatibility.
# Generate with: openssl rand -base64 32
AUTH_SECRET=replace-me-with-a-random-secret
NEXTAUTH_SECRET=replace-me-with-a-random-secret

# Server-side backend URL (used inside NextAuth authorize() — never exposed to browser)
BACKEND_URL=http://localhost:8080

# Client-side backend URL for local dev.
# LEAVE EMPTY IN PRODUCTION — Caddy proxies /api/* to the backend on the same origin,
# so api-client.ts will use relative paths (API_BASE = "") which avoids CORS entirely.
NEXT_PUBLIC_BACKEND_URL=http://localhost:8080
